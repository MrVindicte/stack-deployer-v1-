# ============================================================
# Stack Deployer — Configuration
# ============================================================
# Copier ce fichier en .env et remplir les valeurs

# --- App ---
APP_NAME="Stack Deployer"
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# --- Database ---
# SQLite pour le dev, PostgreSQL pour la prod
DATABASE_URL=sqlite+aiosqlite:///./stack_deployer.db
# DATABASE_URL=postgresql+asyncpg://deployer:password@localhost:5432/stack_deployer

# --- Proxmox ---
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=stack-deployer
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false
PROXMOX_DEFAULT_NODE=pve
PROXMOX_DEFAULT_STORAGE=local-lvm
PROXMOX_DEFAULT_BRIDGE=vmbr0

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Ansible ---
ANSIBLE_ROLES_PATH=./ansible/roles
ANSIBLE_INVENTORY_PATH=./ansible/inventories
ANSIBLE_PRIVATE_KEY=~/.ssh/id_ed25519

# --- Auth ---
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
FIRST_ADMIN_USER=admin
FIRST_ADMIN_PASSWORD=change-me

# --- Network defaults ---
DEFAULT_VLAN_ID=
DEFAULT_DNS_SERVER=192.168.1.1
DEFAULT_GATEWAY=192.168.1.1
DEFAULT_SUBNET_MASK=24
