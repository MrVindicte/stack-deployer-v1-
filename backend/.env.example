# ============================================================
# Stack Deployer — Configuration
# Copier ce fichier en .env et remplir TOUTES les valeurs
# ============================================================

# --- App ---
APP_NAME="Stack Deployer"
APP_ENV=development
# Générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=false

# CORS — liste des origines autorisées séparées par des virgules
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
# SQLite pour le dev local
DATABASE_URL=sqlite+aiosqlite:///./stack_deployer.db
# PostgreSQL pour la prod (décommenter et remplir)
# DATABASE_URL=postgresql+asyncpg://deployer:POSTGRES_PASSWORD@localhost:5432/stack_deployer

# --- PostgreSQL (utilisé par docker-compose) ---
POSTGRES_PASSWORD=change-me-strong-password

# --- Proxmox ---
# IP/hostname de votre serveur Proxmox VE
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
# Nom du token API créé dans Proxmox (Datacenter > API Tokens)
PROXMOX_TOKEN_NAME=stack-deployer
# Valeur UUID du token
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Mettre true si vous avez un certificat TLS valide sur Proxmox
PROXMOX_VERIFY_SSL=false
PROXMOX_DEFAULT_NODE=pve
PROXMOX_DEFAULT_STORAGE=local-lvm
PROXMOX_DEFAULT_BRIDGE=vmbr0

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Ansible ---
ANSIBLE_ROLES_PATH=./ansible/roles
ANSIBLE_INVENTORY_PATH=./ansible/inventories
# Chemin vers la clé SSH privée pour se connecter aux VMs Linux
ANSIBLE_PRIVATE_KEY=~/.ssh/id_ed25519
# Utilisateur SSH sur les VMs Linux (généralement root pour les templates)
ANSIBLE_USER=root
# Credentials WinRM pour les VMs Windows
ANSIBLE_WINRM_USER=Administrator
ANSIBLE_WINRM_PASSWORD=change-me

# --- Auth ---
JWT_ALGORITHM=HS256
# Durée de validité du token en minutes (480 = 8h)
JWT_EXPIRE_MINUTES=480
# Compte admin créé automatiquement au premier démarrage
FIRST_ADMIN_USER=admin
FIRST_ADMIN_PASSWORD=change-me-strong-password

# --- Network defaults ---
# Laisser vide pour ne pas taguer les VMs dans un VLAN
DEFAULT_VLAN_ID=
DEFAULT_DNS_SERVER=192.168.1.1
DEFAULT_GATEWAY=192.168.1.1
DEFAULT_SUBNET_MASK=24

# --- Deployment tuning ---
# Secondes d'attente après le démarrage des VMs avant de tenter Ansible
VM_BOOT_WAIT_SECONDS=120
# Nombre de tentatives pour récupérer l'IP via l'agent Proxmox
VM_IP_RETRY_COUNT=15
# Secondes entre chaque tentative de récupération d'IP
VM_IP_RETRY_INTERVAL=20

# --- Secrets des stacks (injectés comme extra_vars Ansible) ---
# Laisser vide pour utiliser les valeurs par défaut des rôles
# Active Directory
LAB_AD_SAFE_MODE_PASSWORD=
# Monitoring
GRAFANA_ADMIN_PASSWORD=
# Dev Platform
JENKINS_ADMIN_PASSWORD=
GITEA_ADMIN_PASSWORD=
# Web Stack
MARIADB_ROOT_PASSWORD=
# SonarQube
SONARQUBE_DB_PASSWORD=
# MinIO
MINIO_ROOT_PASSWORD=

# --- SSH Keys (docker-compose) ---
# Dossier contenant votre clé SSH à monter dans le conteneur Celery
# Windows: SSH_KEY_DIR=C:/Users/VotreNom/.ssh
# Linux/Mac: SSH_KEY_DIR=/home/VotreNom/.ssh
SSH_KEY_DIR=/root/.ssh
