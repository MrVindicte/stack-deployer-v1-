# Force LF line endings for all text files
# This prevents CRLF/LF conflicts between Windows and Linux/Mac

* text=auto eol=lf

# Explicitly LF for shell scripts and configs
*.sh        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.py        text eol=lf
*.js        text eol=lf
*.vue       text eol=lf
*.ts        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.ini       text eol=lf
*.cfg       text eol=lf
*.toml      text eol=lf
*.env       text eol=lf
*.env.*     text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf

# Binary files — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
